#include <iostream>
using namespace std;

int main() {

    int b20, b10, b5, b1, monto, saldo;
    int e20=0,e10=0,e5=0,e1=0;
    int disponible;

    cin >> b20 >> b10 >> b5 >> b1;
    cin >> saldo;
    cin >> monto;

    disponible = b20*20 + b10*10 + b5*5 + b1;

    if(monto <= 0 || monto > saldo || monto > disponible){
        cout << "Operacion no valida";
    } else {

        e20 = min(b20, monto/20);
        monto -= e20*20;

        e10 = min(b10, monto/10);
        monto -= e10*10;

        e5 = min(b5, monto/5);
        monto -= e5*5;

        e1 = min(b1, monto);
        monto -= e1;

        if(monto != 0){
            cout << "No exacto";
        } else {
            cout << e20 << " " << e10 << " " << e5 << " " << e1;
        }
    }

    return 0;
}
