#include <iostream>
using namespace std;

int main(){

    float ant,act,consumo,costo,total;
    int habitantes;
    string tipo;
    bool alto,deuda;

    cout << "Lectura anterior: ";
    cin >> ant;

    cout << "Lectura actual: ";
    cin >> act;

    if(act < ant){
        cout << "Error: lectura invalida" << endl;
    } else {

        cout << "Tipo de vivienda (social/normal): ";
        cin >> tipo;

        cout << "Numero de habitantes: ";
        cin >> habitantes;

        cout << "Tiene deuda anterior? (1=Si, 0=No): ";
        cin >> deuda;

        cout << "Tiene artefactos de alto consumo? (1=Si, 0=No): ";
        cin >> alto;

        consumo = act - ant;

        if(consumo <= 100)
            costo = consumo * 0.1;
        else if(consumo <= 200)
            costo = consumo * 0.15;
        else
            costo = consumo * 0.2;

        total = costo;

        if(deuda)
            total *= 1.1;

        if(tipo == "social" && consumo < 80)
            total *= 0.8;

        cout << "\n--- RESULTADOS ---" << endl;
        cout << "Consumo: " << consumo << endl;
        cout << "Costo base: " << costo << endl;
        cout << "Total: " << total << endl;

        if(consumo / habitantes > 50)
            cout << "Alerta: consumo alto por habitante" << endl;

        if(alto && consumo > 200)
            cout << "Riesgo: alto consumo electrico" << endl;
    }

    return 0;
}
