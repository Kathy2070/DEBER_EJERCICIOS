#include <iostream>
using namespace std;

int main(){

    float ant,act,consumo,costo,total;
    int habitantes;
    string tipo;
    bool alto,deuda;

    cin>>ant>>act;

    if(act<ant){
        cout<<"Error";
    } else {

        consumo=act-ant;

        if(consumo<=100) costo=consumo*0.1;
        else if(consumo<=200) costo=consumo*0.15;
        else costo=consumo*0.2;

        total=costo;

        if(deuda) total*=1.1;

        if(tipo=="social" && consumo<80)
            total*=0.8;

        if(consumo/habitantes>50)
            cout<<"Alerta";

        cout<<total;
    }

    return 0;
}
